# =============================================================================
# KhataBox — Consolidated Environment Variables
# =============================================================================
# Copy this file to .env or distribute to:
#   frontend/.env    → Next.js frontend (subset: NEXT_PUBLIC_*, AUTH_*)
#   backend/.env     → FastAPI backend (subset: DATABASE_URL, SECRET_KEY, etc.)
# =============================================================================
# REQUIRED values will crash the app if missing.
# OPTIONAL values degrade gracefully — leave blank to skip the feature.
# =============================================================================

# =============================================================================
# FRONTEND (Next.js) — Required
# =============================================================================

# Backend API URL — the base URL of the FastAPI backend
#   Dev: http://localhost:8002
#   Prod: https://khatabox-api.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8002

# Auth.js secret — used to encrypt JWT tokens and cookies
# Generate: openssl rand -base64 32  (or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Public URL of the frontend — used for auth callbacks
#   Dev: http://localhost:3000
#   Prod: https://khatabox.vercel.app
AUTH_URL=http://localhost:3000

# =============================================================================
# BACKEND (FastAPI) — Database
# =============================================================================

# PostgreSQL connection string (async with asyncpg)
#   Dev: postgresql+asyncpg://khatabox:khatabox123@localhost:5432/khatabox
#   Prod: postgresql+asyncpg://user:password@ep-xyz.us-east-2.aws.neon.tech/khatabox?sslmode=require
DATABASE_URL=postgresql+asyncpg://khatabox:khatabox123@localhost:5432/khatabox

# =============================================================================
# BACKEND (FastAPI) — JWT Authentication
# =============================================================================

# Secret key for signing JWT tokens (REQUIRED — min 32 chars)
SECRET_KEY=khatabox-dev-secret-change-in-prod

# JWT algorithm (leave as HS256 unless you know what you're doing)
ALGORITHM=HS256

# Access token expiry in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiry in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# BACKEND (FastAPI) — Redis (Caching & Task Queue)
# =============================================================================

# Redis connection string — OPTIONAL (gracefully degrades)
#   Dev: redis://localhost:6379
#   Prod: rediss://default:password@us1-kind-redis-12345.upstash.io:6379
REDIS_URL=redis://localhost:6379

# =============================================================================
# BACKEND (FastAPI) — Email (Resend)
# =============================================================================

# Resend API key — OPTIONAL (email notifications disabled without it)
# Sign up: https://resend.com
RESEND_API_KEY=

# =============================================================================
# BACKEND (FastAPI) — Error Tracking (Sentry)
# =============================================================================

# Sentry DSN — OPTIONAL (no error reporting without it)
# Sign up: https://sentry.io
SENTRY_DSN=

# =============================================================================
# BACKEND (FastAPI) — Analytics (PostHog)
# =============================================================================

# PostHog API key — OPTIONAL (no event tracking without it)
# Sign up: https://posthog.com
POSTHOG_API_KEY=

# PostHog host — default: https://us.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# BACKEND (FastAPI) — CORS
# =============================================================================

# Comma-separated list of allowed CORS origins (REQUIRED)
# Must include the production frontend URL
CORS_ORIGINS=http://localhost:3000,https://khatabox.vercel.app

# =============================================================================
# BACKEND (FastAPI) — File Storage (Cloudflare R2)
# =============================================================================

# R2 endpoint URL — OPTIONAL (image uploads disabled without it)
# Sign up: https://cloudflare.com
R2_ENDPOINT_URL=

# R2 access key ID
R2_ACCESS_KEY_ID=

# R2 secret access key
R2_SECRET_ACCESS_KEY=

# R2 bucket name
R2_BUCKET_NAME=khatabox

# R2 public URL for serving uploaded files
R2_PUBLIC_URL=
