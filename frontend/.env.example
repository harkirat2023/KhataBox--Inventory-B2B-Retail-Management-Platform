# =============================================================================
# KhataBox Frontend — Environment Variables
# =============================================================================
# Copy this file to .env in the frontend/ directory.
# =============================================================================

# Backend API URL (REQUIRED)
#   Dev: http://localhost:8002
#   Prod: https://khatabox-api.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8002

# Auth.js secret for JWT/cookie encryption (REQUIRED)
# Generate: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Public URL of the frontend (REQUIRED for auth callbacks)
#   Dev: http://localhost:3000
#   Prod: https://khatabox.vercel.app
AUTH_URL=http://localhost:3000
