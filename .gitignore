# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/frontend/node_modules
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/frontend/coverage

# next.js
/frontend/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# logs
/logs

# runtime helper scripts
backend/_check_seed.py
logs/*.log
logs/*.txt
!logs/.gitkeep
!logs/README.md

# debug
npm-debug.log*
yarn-debug.log*
backend/*.log
yarn-error.log*
.pnpm-debug.log*

# python
__pycache__/
*.pyc
.pytest_cache/
backend/venv/
.venv/

# env files (can opt-in for committing if needed)
.env*


!.env.example
!frontend/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
frontend/next-env.d.ts
